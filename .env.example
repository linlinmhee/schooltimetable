# Azure OpenAI Credentials.
#
# These never reach the browser — they're consumed by the Netlify Function
# at netlify/functions/azure.js, which proxies all calls to Azure.
#
# Local development (`netlify dev`): copy this file to `.env` and fill in
# real values; the Netlify CLI will inject them into the function runtime.
# Production: set the same variables in
#   Netlify dashboard → Site settings → Environment variables.
#
# `.env` is gitignored — never commit real keys.
#
# All five variables are REQUIRED (no defaults in code).

AZURE_OPENAI_API_KEY=<your-azure-key>
AZURE_OPENAI_ENDPOINT=<your-azure-endpoint-url>
AZURE_OPENAI_API_VERSION=<api-version-eg-2025-01-01-preview>
AZURE_OPENAI_CHAT_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_IMAGE_DEPLOYMENT=<your-image-deployment-name>
